# Application Settings
APP_NAME=KMS-IAM
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Database
DATABASE_URL=sqlite:///./data/kms-iam.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/kms_iam

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Cryptography
MASTER_KEY_PATH=./data/master.key

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./data/audit.log

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# For production, specify exact domains:
# CORS_ORIGINS=https://app.example.com,https://api.example.com

# Optional: API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Optional: HSM Configuration (if using hardware security module)
# HSM_TYPE=pkcs11
# HSM_LIBRARY_PATH=/path/to/pkcs11.so
# HSM_PIN=0000
# HSM_SLOT_ID=0
